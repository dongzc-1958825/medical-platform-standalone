      { name: '布洛芬', en: 'ibuprofen', category: '非甾体抗炎药', pattern: /布洛芬|ibuprofen/i, defaultUsage: '0.2-0.4g/次，3-4次/天', sideEffects: ['胃肠道反应', '头痛'] },
      { name: '双氯芬酸钠', en: 'diclofenac', category: '非甾体抗炎药', pattern: /双氯芬酸钠|diclofenac/i, defaultUsage: '25-50mg/次，3次/天', sideEffects: ['胃肠道不适'] },
      { name: '塞来昔布', en: 'celecoxib', category: '非甾体抗炎药', pattern: /塞来昔布|celecoxib/i, defaultUsage: '100-200mg/次，1-2次/天', sideEffects: ['胃肠道刺激小'] },
      { name: '别嘌醇', en: 'allopurinol', category: '黄嘌呤氧化酶抑制剂', pattern: /别嘌醇|allopurinol/i, defaultUsage: '起始50-100mg/天，逐渐加量', sideEffects: ['皮疹', '肝功能异常'] },
      { name: '非布司他', en: 'febuxostat', category: '黄嘌呤氧化酶抑制剂', pattern: /非布司他|febuxostat/i, defaultUsage: '起始20mg/天，最大80mg/天', sideEffects: ['肝功能异常'] },
      { name: '苯溴马隆', en: 'benzbromarone', category: '促尿酸排泄药', pattern: /苯溴马隆|benzbromarone/i, defaultUsage: '50mg/天，可增至100mg/天', sideEffects: ['肝损伤'] },
      
      // 神经痛药物
      { name: '加巴喷丁', en: 'gabapentin', category: '抗惊厥药', pattern: /加巴喷丁|gabapentin/i, defaultUsage: '起始300mg睡前，逐渐加量', sideEffects: ['嗜睡', '头晕'] },
