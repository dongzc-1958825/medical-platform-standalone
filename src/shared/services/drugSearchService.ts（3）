      { name: '艾司唑仑', en: 'estazolam', category: '苯二氮䓬类', pattern: /艾司唑仑|estazolam/i, defaultUsage: '1-2mg睡前服用', sideEffects: ['嗜睡', '记忆力下降'] },
      { name: '褪黑素', en: 'melatonin', category: '褪黑素受体激动剂', pattern: /褪黑素|melatonin/i, defaultUsage: '1-3mg睡前1-2小时', sideEffects: ['头痛', '恶心'] }
    ];
  }

  /**
   * 从文本中提取适应症
   */
  private extractIndications(text: string, drugName: string, drugEn: string): string[] {
    const sentences = text.split(/[。；]/);
    for (const sentence of sentences) {
      if ((sentence.includes(drugName) || sentence.includes(drugEn)) && 
          (sentence.includes('用于') || sentence.includes('治疗') || sentence.includes('适应'))) {
        return [sentence.trim()];
      }
    }
    return [];
  }

  /**
   * 从文本中提取禁忌症
   */
  private extractContraindications(text: string, drugName: string): string[] {
    const sentences = text.split(/[。；]/);
    for (const sentence of sentences) {
      if (sentence.includes(drugName) && 
          (sentence.includes('禁用') || sentence.includes('禁忌') || sentence.includes('不宜'))) {
        return [sentence.trim()];
      }
    }
    return [];
  }

  /**
   * 从文本中提取用法
   */
  private extractUsage(text: string, drugName: string): string {
    const sentences = text.split(/[。；]/);
    for (const sentence of sentences) {
      if (sentence.includes(drugName) && 
          (sentence.includes('用法') || sentence.includes('剂量') || sentence.includes('mg'))) {
        return sentence.trim();
      }
    }
    return '';
  }

  /**
   * 从网络搜索
   */
  private async searchFromWeb(keyword: string): Promise<DrugInfo[]> {
    try {
      const response = await fetch(`${this.backendUrl}/search`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ keyword, type: 'drug' })
      });
      
      if (!response.ok) return [];
      
      const data = await response.json();
      return this.parseResults(data, keyword);
      
    } catch (error) {
      console.error('网络搜索失败:', error);
      return [];
    }
  }

  /**
   * 解析搜索结果
   */
  private parseResults(data: any, keyword: string): DrugInfo[] {
    const results: DrugInfo[] = [];
    
    if (data.drugs?.source === 'yaozhi' && data.drugs.results) {
      for (const item of data.drugs.results.slice(0, 5)) {
        results.push({
          id: `yaozhi-${Date.now()}`,
          name: item.name,
          nameCn: this.extractChineseName(item.name),
          category: '药品',
          indications: [item.indications || '请参考药品说明书'],
          contraindications: ['请参考药品说明书'],
          usage: '请遵医嘱',
          sideEffects: [],
          manufacturer: item.manufacturer,
          source: '药智数据',
          sourceUrl: item.url,
          matchScore: 80
        });
      }
    }
    
    return results;
  }

  /**
   * 提取中文名
   */
  private extractChineseName(text: string): string {
    const match = text.match(/[\u4e00-\u9fa5]{2,15}/);
    return match ? match[0] : text.substring(0, 20);
  }

  /**
   * 去重
   */
  private deduplicate(drugs: DrugInfo[]): DrugInfo[] {
    const seen = new Set();
    return drugs.filter(drug => {
      if (seen.has(drug.name)) return false;
      seen.add(drug.name);
      return true;
    });
  }

  /**
   * AI推荐
   */
  async recommend(symptom: string, patientInfo?: any): Promise<DrugRecommendation> {
    const drugs = await this.searchBySymptom(symptom);
    const searchUrl = `https://www.baidu.com/s?wd=${encodeURIComponent(symptom + ' 治疗 药品')}`;
    
    // 按类别分组
    const groups = new Map<string, DrugInfo[]>();
    for (const drug of drugs) {
      const cat = drug.category;
      if (!groups.has(cat)) groups.set(cat, []);
      groups.get(cat)!.push(drug);
    }
    
    const categories = Array.from(groups.entries()).map(([name, drugs]) => ({
      name,
      description: this.getCategoryDescription(name),
      drugs
    }));
    
    return {
      summary: `关于"${symptom}"的治疗药物：`,
      searchUrl,
      categories
    };
  }

  private getCategoryDescription(category: string): string {
    const desc: Record<string, string> = {
      '抗炎药': '急性期首选，快速控制炎症',
      '非甾体抗炎药': '缓解疼痛和炎症',
      '黄嘌呤氧化酶抑制剂': '抑制尿酸生成，长期降尿酸',
      '促尿酸排泄药': '促进尿酸排泄',
      '抗惊厥药': '神经病理性疼痛的一线用药',
      '三环类抗抑郁药': '改善神经痛和睡眠',
      '非苯二氮䓬类': '快速入睡，依赖性低',
      '苯二氮䓬类': '抗焦虑助眠，易成瘾',
      '褪黑素受体激动剂': '调节生物节律，副作用小'
    };
    return desc[category] || '相关药物';
  }
}

export const drugSearchService = new DrugSearchService();

