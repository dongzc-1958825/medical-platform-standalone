// src/shared/services/drugSearchService.ts

/**
 * 药品搜索服务 - 核心服务
 * 功能：搜索药品信息，阅读并提取关键数据
 */

export interface DrugInfo {
  id: string;
  name: string;           // 英文名
  nameCn: string;         // 中文名
  category: string;       // 药物类别
  indications: string[];  // 适应症
  contraindications: string[]; // 禁忌症
  usage: string;          // 用法用量
  sideEffects: string[];  // 副作用
  manufacturer?: string;
  source: string;
  sourceUrl?: string;
  matchScore?: number;
}

export interface DrugRecommendation {
  summary: string;
  searchUrl: string;
  categories: {
    name: string;
    description: string;
    drugs: DrugInfo[];
  }[];
}

class DrugSearchService {
  
  private backendUrl = 'http://localhost:3001/api';

  /**
   * 根据症状搜索药品
   */
  async searchBySymptom(symptom: string): Promise<DrugInfo[]> {
    console.log(`🔍 搜索药品: ${symptom}`);
    
    // 1. 优先从中华医学期刊搜索并阅读
    const yiigleResults = await this.searchFromYiigle(symptom);
    if (yiigleResults.length > 0) {
      console.log(`✅ 中华医学期刊返回 ${yiigleResults.length} 种药品`);
      return yiigleResults;
    }
    
    // 2. 其他网络搜索
    const webResults = await this.searchFromWeb(symptom);
    if (webResults.length > 0) {
      console.log(`✅ 网络搜索返回 ${webResults.length} 种药品`);
      return webResults;
    }
    
    // 3. 返回搜索链接
    console.log(`⚠️ 未找到"${symptom}"的相关药品信息`);
    return [{
      id: 'search-link',
      name: `在百度搜索"${symptom} 药品"`,
      nameCn: `百度搜索`,
      category: '搜索建议',
      indications: [`点击查看百度搜索结果`],
      contraindications: [],
      usage: '',
      sideEffects: [],
      source: '百度搜索',
      sourceUrl: `https://www.baidu.com/s?wd=${encodeURIComponent(symptom + ' 药品')}`,
      matchScore: 100
    }];
  }

  /**
   * 从中华医学期刊搜索并阅读文章
   */
  private async searchFromYiigle(keyword: string): Promise<DrugInfo[]> {
    try {
      const response = await fetch(
        `${this.backendUrl}/yiigle/search?q=${encodeURIComponent(keyword)}&page=1`
      );
      
      if (!response.ok) return [];
      
      const data = await response.json();
      
      if (data.data && data.data.length > 0) {
        console.log(`📖 阅读 ${data.data.length} 篇文章，提取药品信息...`);
        
        // 阅读每篇文章，提取药品信息
        const allDrugs: DrugInfo[] = [];
        
        for (const article of data.data) {
          const drugs = this.extractDrugsFromArticle(article, keyword);
          allDrugs.push(...drugs);
        }
        
        // 去重
        const unique = this.deduplicate(allDrugs);
        console.log(`📊 提取到 ${unique.length} 种药品`);
        return unique;
      }
      
      return [];
      
    } catch (error) {
      console.error('中华医学期刊搜索失败:', error);
      return [];
    }
  }

  /**
   * 从文章中提取药品信息（阅读并理解）
   */
  private extractDrugsFromArticle(article: any, keyword: string): DrugInfo[] {
    const drugs: DrugInfo[] = [];
    const text = (article.title + ' ' + article.abstract).toLowerCase();
    
    // 定义药品模式库（基于真实药品知识）
    const drugPatterns = this.getDrugPatterns();
    
    for (const pattern of drugPatterns) {
      if (pattern.pattern.test(text)) {
        // 提取适应症
        const indications = this.extractIndications(text, pattern.name, pattern.en);
        // 提取禁忌症
        const contraindications = this.extractContraindications(text, pattern.name);
        // 提取用法
        const usage = this.extractUsage(text, pattern.name);
        
        drugs.push({
          id: `drug-${pattern.en}-${Date.now()}`,
          name: pattern.en,
          nameCn: pattern.name,
          category: pattern.category,
          indications: indications.length > 0 ? indications : [`适用于${keyword}的治疗`],
          contraindications: contraindications.length > 0 ? contraindications : ['请参考药品说明书'],
          usage: usage || pattern.defaultUsage,
          sideEffects: pattern.sideEffects || [],
          manufacturer: article.journal,
          source: '中华医学期刊',
          sourceUrl: article.url,
          matchScore: 85
        });
      }
    }
    
    return drugs;
  }

