// src/pages/mobile/MobileCommunityLifePage.tsx
import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import {
  Users,
  MessageCircle,
  Activity,
  Clock,
  ChevronRight,
  Heart,
  Brain,
  Beaker,
  BookOpen,
  Activity as ActivityIcon
} from 'lucide-react';
import { communityLifeService } from '../../shared/services/communityLifeService';
import { CommunityStats, CommunityActivity } from '../../shared/types/community';

const MobileCommunityLifePage: React.FC = () => {
  const navigate = useNavigate();
  const [stats, setStats] = useState<CommunityStats | null>(null);
  const [activities, setActivities] = useState<CommunityActivity[]>([]);

  useEffect(() => {
    loadData();
  }, []);

  const loadData = () => {
    const communityStats = communityLifeService.getStats();
    const recentActivities = communityLifeService.getActivities(10);
    setStats(communityStats);
    setActivities(recentActivities);
  };

  const getTypeIcon = (type: CommunityActivity['type']) => {
    switch(type) {
      case 'new_member': return <Users className="w-4 h-4 text-green-500" />;
      case 'new_post': return <MessageCircle className="w-4 h-4 text-blue-500" />;
      case 'new_comment': return <MessageCircle className="w-4 h-4 text-orange-500" />;
      case 'new_event': return <Activity className="w-4 h-4 text-purple-500" />;
      default: return <Activity className="w-4 h-4 text-gray-500" />;
    }
  };

  const formatTime = (dateString: string) => {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return '刚刚';
    if (diffMins < 60) return `${diffMins}分钟前`;
    if (diffHours < 24) return `${diffHours}小时前`;
    if (diffDays < 7) return `${diffDays}天前`;
    return date.toLocaleDateString();
  };

  return (
    <div className="min-h-screen bg-gray-50">
      {/* 顶部标题 */}
      <div className="bg-gradient-to-r from-green-600 to-teal-600 px-5 pt-8 pb-6">
        <h1 className="text-2xl font-bold text-white mb-2">社区生活</h1>
        <p className="text-green-100 text-sm">
          连接志同道合的伙伴，分享生活的点滴
        </p>
      </div>

      {/* 统计卡片 */}
      {stats && (
        <div className="px-4 -mt-5 mb-4">
          <div className="bg-white rounded-xl shadow-sm p-4">
            <div className="grid grid-cols-3 gap-2 text-center">
              <div>
                <div className="text-2xl font-bold text-gray-900">{stats.totalCommunities}</div>
                <div className="text-xs text-gray-500">社群总数</div>
              </div>
              <div className="border-l border-r border-gray-100">
                <div className="text-2xl font-bold text-gray-900">{stats.totalMembers}</div>
                <div className="text-xs text-gray-500">总成员</div>
              </div>
              <div>
                <div className="text-2xl font-bold text-gray-900">{stats.todayActive}</div>
                <div className="text-xs text-gray-500">今日动态</div>
              </div>
            </div>
            <div className="flex items-center justify-center gap-4 mt-2 pt-2 border-t border-gray-100 text-xs">
              <span className="flex items-center gap-1 text-gray-500">
                <MessageCircle className="w-3 h-3" />
                今日 {stats.todayNewPosts} 帖
              </span>
              <span className="flex items-center gap-1 text-gray-500">
                <Users className="w-3 h-3" />
                新增 {stats.todayNewMembers} 人
              </span>
            </div>
          </div>
        </div>
      )}

      {/* 社区分类入口 */}
      <div className="px-4 mb-6">
        <div className="grid grid-cols-2 gap-4">
          {/* 专病社区卡片 */}
          <div
            onClick={() => navigate('/mobile/community/disease')}
            className="bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all cursor-pointer active:bg-gray-50 border border-gray-100"
          >
            <div className="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mb-3">
              <Heart className="w-6 h-6 text-red-600" />
            </div>
            <h3 className="font-semibold text-gray-900 mb-1">专病社区</h3>
            <p className="text-xs text-gray-500 mb-2">按病种分类的互助社区</p>
            <div className="flex items-center text-xs text-red-600">
              <span>12个病种</span>
              <ChevronRight className="w-3 h-3 ml-1" />
            </div>
          </div>

          {/* 其他社区卡片 */}
          <div
            onClick={() => navigate('/mobile/community/other')}
            className="bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all cursor-pointer active:bg-gray-50 border border-gray-100"
          >
            <div className="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mb-3">
              <Users className="w-6 h-6 text-teal-600" />
            </div>
            <h3 className="font-semibold text-gray-900 mb-1">其他社区</h3>
            <p className="text-xs text-gray-500 mb-2">心理健康、中药研学等</p>
            <div className="flex items-center text-xs text-teal-600">
              <span>6个社群</span>
              <ChevronRight className="w-3 h-3 ml-1" />
            </div>
          </div>
        </div>
      </div>

      {/* 今日动态 */}
      <div className="px-4 mb-6">
        <div className="flex items-center justify-between mb-3">
          <h2 className="text-base font-semibold text-gray-900 flex items-center gap-2">
            <ActivityIcon className="w-5 h-5 text-green-600" />
            今日动态
          </h2>
          <span className="text-xs text-gray-400">最新 {activities.length} 条</span>
        </div>

        <div className="bg-white rounded-xl shadow-sm divide-y divide-gray-100">
          {activities.map((activity) => (
            <div key={activity.id} className="p-4 flex items-start gap-3">
              <div className="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center">
                {getTypeIcon(activity.type)}
              </div>
              <div className="flex-1">
                <div className="flex items-center gap-2 mb-0.5">
                  <span className="font-medium text-gray-900">{activity.userName}</span>
                  <span className="text-xs text-gray-400">{activity.communityName}</span>
                </div>
                <p className="text-sm text-gray-700 mb-1">{activity.content}</p>
                <div className="flex items-center gap-1 text-xs text-gray-400">
                  <Clock className="w-3 h-3" />
                  <span>{formatTime(activity.createdAt)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* 底部导航占位 */}
      <div className="h-20"></div>
    </div>
  );
};

export default MobileCommunityLifePage;
